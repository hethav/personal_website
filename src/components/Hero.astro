---
import Terminal from './Terminal.astro';
---

<section
  class="px-6 md:px-12 py-12 lg:py-24 flex flex-col lg:grid lg:grid-cols-12 gap-12 border-b border-outline-variant/10"
>
  <div class="lg:col-span-7 flex flex-col justify-center">
    <div
      class="inline-block self-start px-2 py-1 bg-primary-container/10 border border-primary-container/20 mb-6"
    >
      <span
        class="text-primary-container font-mono text-xs font-bold tracking-widest"
        >SYSTEM INITIALIZED // KERNEL LOADED</span
      >
    </div>
    <h1
      class="text-[4rem] md:text-[8rem] font-black font-headline text-primary tracking-tighter leading-none mb-4 uppercase"
    >
      HETHAV
    </h1>
    <p
      class="text-lg md:text-2xl font-headline text-on-surface-variant tracking-[0.2em] uppercase font-light"
    >
      v1.9.0-STABLE // <span class="text-primary-container"
        >Backend Architect</span
      >
    </p>
    <div class="mt-12 flex flex-wrap gap-4">
      <button
        class="bg-primary-container text-on-primary px-8 py-3 font-headline font-bold uppercase tracking-widest text-sm hover:shadow-[0_0_20px_rgba(0,255,65,0.4)] transition-all"
        >Execute_Inquiry</button
      >
      <button
        class="border border-outline-variant/40 text-primary px-8 py-3 font-headline font-bold uppercase tracking-widest text-sm hover:bg-surface-container transition-all"
        >$ View_Manifest</button
      >
    </div>
  </div>
  <div class="lg:col-span-5 flex items-start">
    <Terminal />
  </div>
</section>
