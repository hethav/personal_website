---
import Terminal from './Terminal.astro';
---

<section
  class="px-6 md:px-12 py-8 lg:py-16 flex flex-col lg:grid lg:grid-cols-12 gap-8 border-b border-outline-variant/10"
>
  <div class="lg:col-span-6 flex flex-col justify-center">
    <div
      class="inline-block self-start px-2 py-1 bg-primary-container/10 border border-primary-container/20 mb-6"
    >
      <span
        class="text-primary-container font-mono text-xs tracking-widest"
        >hethav@website:~$ /welcome</span
      >
    </div>
    <h1
      class="text-[4rem] md:text-[8rem] font-black font-headline text-primary tracking-tighter leading-none mb-4 uppercase"
    >
      HETHAV
    </h1>
    <p
      class="text-lg md:text-2xl font-headline text-primary-container tracking-[0.2em] uppercase font-light"
    >
      Lead Product Manager
    </p>
    <div class="mt-8">
      <a
        href="https://calendly.com/hethav/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-primary-container text-on-primary px-12 py-4 font-headline font-bold uppercase tracking-widest text-base hover:shadow-[0_0_20px_rgba(0,255,65,0.4)] transition-all inline-block"
        >BOOK_A_CHAT</a
      >
    </div>
  </div>
  <div class="lg:col-span-6 flex items-stretch">
    <Terminal />
  </div>
</section>
