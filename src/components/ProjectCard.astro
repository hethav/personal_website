---
interface Props {
  index: string;
  title: string;
  description: string;
  tags: string[];
}
const { index, title, description, tags } = Astro.props;
---

<div
  class="bg-surface-container-low border-t-2 border-primary-container p-6 flex flex-col glow-border transition-all group"
>
  <div class="flex justify-between items-start mb-8">
    <span class="font-mono text-[10px] text-primary-container">{index}</span>
    <span
      class="material-symbols-outlined text-primary-container group-hover:rotate-45 transition-transform"
      >north_east</span
    >
  </div>
  <h3
    class="font-headline font-bold text-lg text-primary uppercase mb-4 tracking-tight"
  >
    {title}
  </h3>
  <p class="text-on-surface-variant font-body text-xs leading-relaxed mb-8 flex-1">
    {description}
  </p>
  <div class="flex gap-2">
    {
      tags.map((tag) => (
        <span class="text-[9px] font-mono px-2 py-0.5 border border-outline-variant/30 text-on-surface-variant">
          {tag}
        </span>
      ))
    }
  </div>
</div>
