---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    index: 'MOD_01',
    title: 'Kube_Hydra',
    description:
      'High-availability orchestration layer for distributed micro-clusters. Built with Go and Rust.',
    tags: ['GO', 'K8S', 'GRPC'],
  },
  {
    index: 'MOD_02',
    title: 'Void_Vault',
    description:
      'Encrypted cold-storage engine for petabyte-scale metadata. Zero-knowledge architecture.',
    tags: ['RUST', 'AES-256'],
  },
  {
    index: 'MOD_03',
    title: 'Flux_Relay',
    description:
      'Low-latency edge messaging bus with sub-millisecond propagation across global nodes.',
    tags: ['ELIXIR', 'UDP'],
  },
  {
    index: 'MOD_04',
    title: 'Synth_Node',
    description:
      'Auto-scaling serverless environment specifically tuned for heavy computational ML workloads.',
