  >
    <div>
      <h2
        class="text-3xl font-headline font-bold text-primary tracking-tighter uppercase"
      >
        EXPERIENCE
      </h2>
    </div>
    <span class="text-on-surface-variant font-mono text-[10px]">COUNT: 04</span>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {projects.map((p) => <ProjectCard {...p} />)}
  </div>
</section>
